# Copy to `.env.agent` and fill in. This file holds your agent WALLET KEY —
# keep it out of git (it is already covered by ../.gitignore: .env.*).
# It is read only by the Node bot; it is NEVER bundled into the browser app.

# Agent wallet private key (0x...). Used to sign permits + on-chain txs.
# Generate one with:  node agent-bot.mjs new-wallet
MCCLAW_PRIVATE_KEY=

# Agent X-API-Key. Printed when you register (../register-mcclaw.mjs) or via
# `recover-key`. Optional for `balance`/`watch`, required for everything else.
MCCLAW_API_KEY=

# Base RPC endpoint.
#   https://...  → falls back to polling every ~12s
#   wss://...    → real-time WebSocket event subscriptions (recommended for `watch`)
# Public default is fine for low volume; use your own provider (Alchemy/Infura) for wss.
MCCLAW_RPC_URL=https://mainnet.base.org

# API base URL (rarely changed).
MCCLAW_API_URL=https://mcclaw.io/api/v1
